@page "/month/{Date}"
@using Microsoft.Extensions.Logging
@using WorkJournal.Components.Component.MonthCalendar
@using WorkJournal.Models.MonthCalendar

@inject ILogger<Month> Logger
@inject IPageTitleService PageTitleService

<div class="w-full h-full flex flex-col justify-center align-center">
    <div class="flex flex-1 flex-col min-h-0 gap-2">
        <MonthCalendarHeader CurrentDate="CurrentDate"
                             Weekdays="Weekdays"
                             OnPrevMonth="PrevMonth"
                             OnNextMonth="NextMonth"
                             OnYearSelect="ChangeYear"
                             OnMonthSelect="ChangeMonth" />
        <MonthCalendarGrid Days="Days"
                           CurrentDate="CurrentDate"
                           SelectedWeek="_selectedWeek"
                           OnWeekSelected="SelectWeek" />
    </div>
</div>

@code{
    [Parameter] public string? Date { get; set; }
    DateTime CurrentDate = DateTime.Now;

    List<CalendarCell> Days = new List<CalendarCell>();
    List<string> Weekdays = new List<string>();

    int _selectedWeek = -1;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Date) 
        && DateOnly.TryParseExact(Date, 
            "yyyy-MM-dd", 
            CultureInfo.InvariantCulture, 
            DateTimeStyles.None, 
            out var parsed))
        {
            CurrentDate = parsed.ToDateTime(TimeOnly.MinValue);
        }
        else
        {
            CurrentDate = DateTime.Now;
        }

        PageTitleService.SetPageTitle("Mėnesio kalendorius");
        Days = BuildCalendar(CurrentDate.Year, CurrentDate.Month);
        Weekdays = GetWeekdays();

        base.OnInitialized();
    }

    void ChangeYear(int year)
    {
        CurrentDate = new DateTime(year, CurrentDate.Month, CurrentDate.Day).ToUniversalTime();

        RefreshCalendar();
    }

    void ChangeMonth(int month)
    {
        CurrentDate = new DateTime(CurrentDate.Year, month, CurrentDate.Day).ToUniversalTime();

        RefreshCalendar();
    }

    void PrevMonth()
    {
        Logger.LogInformation("Selecting prev month");
        CurrentDate = CurrentDate.AddMonths(-1);

        RefreshCalendar();
    }

    void NextMonth()
    {
        Logger.LogInformation("Selecting next month");
        CurrentDate = CurrentDate.AddMonths(1);

        RefreshCalendar();
    }

    void SelectWeek(int weekIndex)
    {
        Logger.LogInformation($"Selecting {weekIndex}");
        _selectedWeek = weekIndex;
    }

    void RefreshCalendar()
    {
        Days = BuildCalendar(CurrentDate.Year, CurrentDate.Month);
        Weekdays = GetWeekdays();
    }

    List<CalendarCell> BuildCalendar(int year, int month)
    {
        var firstDay = new DateTime(year, month, 1).ToUniversalTime();
        int daysInMonth = DateTime.DaysInMonth(year, month);
        int startOffset = (int)firstDay.DayOfWeek;

        var cells = new List<CalendarCell>();

        for (int i = 0; i < startOffset; i++)
            cells.Add(new CalendarCell(DateTime.MinValue.ToUniversalTime(), false));

        for (int day = 1; day <= daysInMonth; day++)
            cells.Add(new CalendarCell(new DateTime(year, month, day).ToUniversalTime(), true));

        return cells;
    }

    List<string> GetWeekdays()
    {
        var days = CultureInfo.CurrentCulture
                               .DateTimeFormat
                               .AbbreviatedDayNames
                               .Select(x => CultureInfo.CurrentCulture.TextInfo.ToTitleCase(x))
                               .ToList();

        var sunday = days[0];
        days.RemoveAt(0);
        days.Add(sunday);

        return days;
    }
}